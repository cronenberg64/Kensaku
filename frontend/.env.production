# .env.railway
# Copy this file and set your actual values
# DO NOT commit this file to version control

# Database Configuration
POSTGRES_DB=kensaku
POSTGRES_USER=kensaku_user
POSTGRES_PASSWORD=your_super_secure_password_here_min_32_chars
DATABASE_URL=postgresql://kensaku_user:your_super_secure_password_here_min_32_chars@db:5432/kensaku

# Backend Configuration  
SECRET_KEY=your_fastapi_secret_key_min_32_characters_long_random_string
DEBUG=False

# CORS Configuration (will be set automatically by Railway)
RAILWAY_FRONTEND_URL=https://your-frontend-service.up.railway.app
RAILWAY_BACKEND_URL=https://your-backend-service.up.railway.app
CORS_ORIGINS=https://your-frontend-service.up.railway.app
ALLOWED_HOSTS=your-frontend-service.up.railway.app,localhost

# Frontend Configuration
VITE_API_BASE_URL=https://your-backend-service.up.railway.app
VITE_APP_NAME=Kensaku

# Optional: If you're using AI services
# OPENAI_API_KEY=your_openai_api_key_here
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional: Firebase configuration (if still using Firebase for some features)
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id